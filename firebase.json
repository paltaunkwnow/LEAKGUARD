{
  "functions": {
    "source": "functions"
  },
  "hosting": {
    "public": "./",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "functions/**",
      "proxy/**"
    ],
    "rewrites": [
      {
        "source": "/api/scan",
        "function": "scanProxy"
      },
      {
        "source": "/api/breach-check",
        "function": "breachCheckProxy"
      },
      {
        "source": "/api/breaches-recent",
        "function": "breachesRecentProxy"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
